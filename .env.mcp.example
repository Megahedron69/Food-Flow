# Copy to .env when your Supabase project is ready. Do not commit real values.
# These are read by .vscode/mcp.json via ${env:VAR_NAME}.

# Supabase remote MCP (GitHub Copilot — configured in .vscode/mcp.json).
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Direct Postgres MCP. Use a pooled/read-only connection when possible.
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_DB_URL=

# Optional Context7 key for higher limits/features if you have one.
CONTEXT7_API_KEY=
